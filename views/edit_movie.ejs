<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title>Edit Movie</title>
</head>
<body>
    <div class="container">
        <h1>Edit a new movie in the list!</h1>

        <form action="/" method="POST">
            <div>
                <label for="title">Title:</label>
                <input type="text" id="title" name="title" value=<%= movie.title %> required>
            </div>
            <div>
                <label for="genre">Genre:</label>
                <input type="text" id="genre" name="genre" value=<%= movie.genre %> required>
            </div>
            <div>
                <label for="releaseYear">Release Year:</label>
                <input type="number" id="releaseYear" name="releaseYear" value=<%= movie.releaseYear %> required>
            </div>
            <div>
                <label for="director">Director:</label>
                <input type="text" id="director" name="director" value=<%= movie.director %> required>
            </div>
            <div>
                <label for="rating">Rating (0-10):</label>
                <input type="number" id="rating" name="rating" min="0" max="10" step="0.1" value=<%= movie.rating %> required>
            </div>
            <div>
                <input type="hidden" name="_id" value="<%= movie._id %>">
            </div>
            <div>
                <button type="submit">Edit Movie</button>
            </div>
        </form>
    </div>
</body>
</html>